{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Backend (uvicorn)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"],
      "cwd": "${workspaceFolder}/ai-newspaper/backend",
      "envFile": "${workspaceFolder}/ai-newspaper/.env",
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "Frontend (npm dev)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "${workspaceFolder}/ai-newspaper/frontend",
      "console": "integratedTerminal",
      "serverReadyAction": {
        "pattern": "Local:.*localhost:(\\d+)",
        "uriFormat": "http://localhost:%s",
        "action": "openExternally"
      }
    }
  ],
  "compounds": [
    {
      "name": "🗞️ AI未来新聞 (Full Stack)",
      "configurations": ["Backend (uvicorn)", "Frontend (npm dev)"],
      "stopAll": true,
      "presentation": {
        "hidden": false,
        "group": "",
        "order": 1
      }
    }
  ]
}
